# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# ─── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ─── Model Weights ────────────────────────────────────────────────────────────
# Tracked via DVC — not committed to git
models/yolo11n/weights/
models/yolo11n/exports/
models/yolo11n/results/
# Phase-4 benchmark run workspace (weights/configs; reports live in data/qa_reports)
models/benchmarks/
models/smolvlm2/
models/tts/*.onnx
models/tts/*.onnx.json
# Pretrained base weights auto-downloaded by Ultralytics
yolo11n.pt
yolo11s.pt
# CLIP's own text-encoder weight cache (downloaded by clip.load() when
# YOLO-World's set_classes() runs — CLIP's default download_root, not ours)
/weights/
# Phase-5 auto-annotation backend weights — sha256-pinned in configs/annotation.yaml,
# reproducible via download URL, not tracked in git or DVC
models/annotators/*.pt
# Ultralytics run artifacts
runs/

# ─── Dataset Files ────────────────────────────────────────────────────────────
# Tracked via DVC — not committed to git
data/raw/coco_filtered/
data/raw/openimages_filtered/
data/raw/roboflow_imports/
data/raw/wider_face/
data/raw/custom_captures/
data/raw/negatives/
data/interim/
data/merged/
data/merged_verified/
data/downloads_cache/
data/processed/images/
data/processed/labels/
data/processed/split_report/
# Phase-5 auto-annotation candidates (DVC out of the auto_annotate stage) —
# the verification ledger stays git-tracked (small, cache: false, ADR-P5-01)
data/annotation/candidates/
# Phase-5 CVAT verification batches (DVC out of the frozen
# build_verification_batches stage) — pre-annotation zips are regenerated,
# not hand-edited
data/annotation/batches/
# Phase-5 verified-label deltas (DVC-cached out of the frozen
# import_verified_annotations stage) — the ledger itself stays git-tracked
data/annotation/verified_labels/

# QA artifacts — regenerated by scripts/qa/run_full_qa.py and
# scripts/dataset/11_generate_completeness.py; only the DVC-tracked JSON
# files (cache: false outs/metrics) stay in git
data/qa_reports/*
!data/qa_reports/annotation_qa_report.json
!data/qa_reports/completeness_report.json
!data/qa_reports/coverage_report.json
# Phase-4 validation/benchmark evidence is committed (referenced by docs/06)
!data/qa_reports/phase4_mitigation/
# Phase-5 full-build preflight evidence is committed (referenced by docs/07)
!data/qa_reports/full_build_preflight.*

# ─── Custom Capture Workflow (Phase-3) ────────────────────────────────────────
# Staging inbox for raw phone photos — transient, never tracked
data/capture_inbox/
# Locked real-home eval set — tracked via DVC (ingest_eval_set stage), not git
data/eval/
# Consent records are LOCAL-ONLY: never in git, never a DVC out (no PII in
# the repo or on S3 — see data/consent/README.md)
data/consent/*
!data/consent/README.md

# ─── Local agent tooling (not project code) ──────────────────────────────────
.agents/

# ─── Logs ─────────────────────────────────────────────────────────────────────
# Runtime logs contain potentially sensitive detection history
logs/pipeline/
logs/training/
logs/qa/
*.log
*.jsonl

# ─── Outputs ──────────────────────────────────────────────────────────────────
outputs/visualizations/
outputs/benchmarks/

# ─── DVC Internal ─────────────────────────────────────────────────────────────
.dvc/cache/
.dvc/tmp/

# ─── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.secret
*_secret*
secrets/
api_keys.yaml

# ─── IDE & System ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ─── Testing & Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coverage
.mypy_cache/
.ruff_cache/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Temporary Files ──────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig

