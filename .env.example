# ─── Environment variables — Elderly Assistant System ─────────────────────────
# Copy to .env (gitignored) or export in your shell. None are required for
# the smoke build; missing optional keys cause a graceful skip, not a crash.

# Roboflow Universe API key (free: https://roboflow.com → settings → API).
# Required only when sources.roboflow.datasets in configs/dataset_sources.yaml
# is non-empty; without it the roboflow download stage skips with a warning
# and its classes (medicine_bottle, charger, wire, gas_cylinder) stay empty.
ROBOFLOW_API_KEY=
